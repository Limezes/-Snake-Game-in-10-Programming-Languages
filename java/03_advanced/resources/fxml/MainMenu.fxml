<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.snake.GameController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: linear-gradient(to bottom, #1a1a2e, #16213e);"
      prefWidth="800"
      prefHeight="600">
    
    <Label text="SNAKE GAME"
           textFill="gold"
           style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, gold, 20, 0, 0, 0);">
        <font>
            <Font name="Press Start 2P" size="48"/>
        </font>
    </Label>
    
    <VBox spacing="15" alignment="CENTER">
        <Button text="НОВАЯ ИГРА"
                prefWidth="300"
                prefHeight="50"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;">
            <font>
                <Font name="Press Start 2P" size="14"/>
            </font>
        </Button>
        
        <Button text="ПРОДОЛЖИТЬ"
                prefWidth="300"
                prefHeight="50"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;">
            <font>
                <Font name="Press Start 2P" size="14"/>
            </font>
        </Button>
        
        <Button text="НАСТРОЙКИ"
                prefWidth="300"
                prefHeight="50"
                style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;">
            <font>
                <Font name="Press Start 2P" size="14"/>
            </font>
        </Button>
        
        <Button text="РЕКОРДЫ"
                prefWidth="300"
                prefHeight="50"
                style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;">
            <font>
                <Font name="Press Start 2P" size="14"/>
            </font>
        </Button>
        
        <Button text="ДОСТИЖЕНИЯ"
                prefWidth="300"
                prefHeight="50"
                style="-fx-background-color: #E91E63; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;">
            <font>
                <Font name="Press Start 2P" size="14"/>
            </font>
        </Button>
        
        <Button text="ВЫХОД"
                prefWidth="300"
                prefHeight="50"
                style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;">
            <font>
                <Font name="Press Start 2P" size="14"/>
            </font>
        </Button>
    </VBox>
    
    <Label text="© 2024 Snake Game"
           textFill="#666"
           style="-fx-font-size: 12px;"
           VBox.vgrow="ALWAYS"
           alignment="BOTTOM_CENTER">
        <VBox.margin>
            <Insets bottom="20"/>
        </VBox.margin>
    </Label>
</VBox>
